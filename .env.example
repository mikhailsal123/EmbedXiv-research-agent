NEBIUS_ENDPOINT_URL=https://<your-qwen-endpoint>
NEBIUS_ENDPOINT_TOKEN=<nebius-endpoint-token>

NEBIUS_S3_ENDPOINT_URL=https://storage.<region>.nebius.cloud
NEBIUS_S3_REGION=<region>
NEBIUS_S3_ACCESS_KEY_ID=<object-storage-access-key-id>
NEBIUS_S3_SECRET_ACCESS_KEY=<object-storage-secret-access-key>
NEBIUS_S3_BUCKET=<bucket-name>
NEBIUS_INDEX_PREFIX=arxiv-index

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=verify-full

# Optional. Required only when Semantic Scholar recommendations are enabled.
S2_API_KEY=<semantic-scholar-api-key>
